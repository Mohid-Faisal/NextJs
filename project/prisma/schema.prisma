generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

model User {
  id           Int                  @id @default(autoincrement())
  name         String
  email        String               @unique
  password     String
  role         String               @default("USER")
  platformRole String?
  status       String               @default("PENDING")
  isApproved   Boolean              @default(false)
  approvedAt   DateTime?
  approvedBy   Int?
  createdAt    DateTime             @default(now())
  memberships  OrganizationMember[]
  phone        String?
  address      String?
}

model Organization {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  status        String   @default("active")
  logoUrl       String?
  currency      String   @default("PKR")
  invoicePrefix String?
  createdAt     DateTime @default(now())
  members       OrganizationMember[]
  subscription  Subscription?
  paymentProofs PaymentProof[]
}

model OrganizationMember {
  id             Int          @id @default(autoincrement())
  organizationId Int
  userId         Int
  role           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Plan {
  id                   Int            @id @default(autoincrement())
  code                 String         @unique
  name                 String
  priceMonthlyUsd      Float
  maxUsers             Int
  maxShipmentsPerMonth Int
  features             Json
  subscriptions        Subscription[]
  paymentProofs        PaymentProof[]
}

model Subscription {
  id                   Int          @id @default(autoincrement())
  organizationId       Int          @unique
  planId               Int
  status               String
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                 Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)
}

model Shipment {
  id                Int       @id @default(autoincrement())
  organizationId    Int       @default(1)
  trackingId        String?
  invoiceNumber     String?   @unique
  referenceNumber   String
  agency            String?
  office            String?
  senderName        String
  senderAddress     String
  recipientName     String
  recipientAddress  String
  destination       String
  deliveryTime      String?
  invoiceStatus     String?
  deliveryStatus    String?
  trackingStatus    String?
  trackingStatusHistory Json?
  shippingMode      String?
  packaging         String?
  vendor            String?
  serviceMode       String?
  amount            Int       @default(1)
  packageDescription String?
  weight            Float     @default(0)
  length            Float     @default(0)
  width             Float     @default(0)
  height            Float     @default(0)
  weightVol         Float     @default(0)
  fixedCharge       Float     @default(0)
  decValue          Float     @default(0)
  price             Float     @default(0)
  discount          Float     @default(0)
  fuelSurcharge     Float     @default(0)
  insurance         Float     @default(0)
  customs           Float     @default(0)
  tax               Float     @default(0)
  declaredValue     Float     @default(0)
  reissue           Float     @default(0)
  profitPercentage  Float     @default(0)
  cos               Float     @default(0)
  totalCost         Float
  subtotal          Float     @default(0)
  manualRate        Boolean   @default(false)
  totalPackages     Int       @default(0)
  totalWeight       Float     @default(0)
  totalWeightVol    Float     @default(0)
  shipmentDate      DateTime  @default(now())
  packages          Json?
  packageTotals     Json?
  calculatedValues  Json?
  createdAt         DateTime  @default(now())
  invoices          Invoice[]

  @@unique([organizationId, trackingId])
  @@index([organizationId])
}

model Customers {
  id              Int       @id @default(autoincrement())
  organizationId  Int       @default(1)
  CompanyName     String
  PersonName      String
  Email           String
  Phone           String
  DocumentType    String
  DocumentNumber  String
  DocumentExpiry  String?
  Country         String
  State           String
  City            String
  Zip             String
  Address         String
  ActiveStatus    String
  FilePath        String
  createdAt       DateTime  @default(now())
  currentBalance  Float     @default(0)
  creditLimit     Float     @default(0)
  invoices        Invoice[]
  transactions    CustomerTransaction[]
  creditNotes     CreditNote[]

  @@unique([organizationId, CompanyName])
  @@index([organizationId])
}

model Vendors {
  id             Int       @id @default(autoincrement())
  organizationId Int       @default(1)
  CompanyName    String
  PersonName     String
  Email          String
  Phone          String
  Country        String
  State          String
  City           String
  Zip            String
  Address        String
  createdAt      DateTime  @default(now())
  currentBalance Float     @default(0)
  creditLimit    Float     @default(0)
  invoices       Invoice[]
  transactions   VendorTransaction[]
  debitNotes     DebitNote[]

  @@unique([organizationId, CompanyName])
  @@index([organizationId])
}

model Recipients {
  id                  Int       @id @default(autoincrement())
  organizationId      Int       @default(1)
  CompanyName         String
  PersonName          String
  Email               String
  Phone               String
  Country             String
  State               String
  City                String
  Zip                 String
  Address             String
  isRemoteArea        Boolean   @default(false)
  remoteAreaCompanies Json?
  createdAt           DateTime  @default(now())

  @@unique([organizationId, CompanyName])
  @@index([organizationId])
}

model DeliveryTime {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  name           String
  createdAt      DateTime @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Agency {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  code           String
  name           String
  createdAt      DateTime @default(now())

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Office {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  code           String
  name           String
  createdAt      DateTime @default(now())

  @@unique([organizationId, code])
  @@index([organizationId])
}

model InvoiceStatus {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model DeliveryStatus {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  name           String
  code           String?
  icon           String?
  color          String?
  order          Int?     @default(0)
  status         String?  @default("Active")
  createdAt      DateTime @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ShippingMode {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  name           String
  createdAt      DateTime @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

model PackagingType {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  name           String
  createdAt      DateTime @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ServiceMode {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  name           String
  code           String?
  mode           String?
  currency       String?
  status         String?  @default("Active")
  createdAt      DateTime @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
}

model HsCode {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  code           String
  description    String
  category       String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Zone {
  id             Int     @id @default(autoincrement())
  organizationId Int     @default(1)
  code           String
  country        String
  zone           String
  service        String
  phoneCode      String?

  @@index([organizationId])
  @@index([organizationId, service])
}

model ZoneUpload {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  service        String
  uploadedAt     DateTime @default(now())

  @@unique([organizationId, service])
  @@index([organizationId])
}

model RemoteArea {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  company        String
  country        String
  iataCode       String
  low            String
  high           String
  city           String?
  filename       String?
  uploadedAt     DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, company])
}

model Rate {
  id             Int    @id @default(autoincrement())
  organizationId Int    @default(1)
  weight         Float
  vendor         String
  service        String
  zone           String
  price          Int
  docType        String

  @@index([organizationId])
  @@index([organizationId, vendor, service])
}

model filename {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  filename       String
  vendor         String
  service        String
  fileType       String
  uploadedAt     DateTime @default(now())

  @@unique([organizationId, vendor, service, fileType])
  @@index([organizationId])
}

model CustomerTransaction {
  id              Int       @id @default(autoincrement())
  organizationId  Int       @default(1)
  customerId      Int
  customer        Customers @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            String
  amount          Float
  description     String
  reference       String?
  invoice         String?
  previousBalance Float
  newBalance      Float
  createdAt       DateTime  @default(now())

  @@index([customerId])
  @@index([createdAt])
  @@index([organizationId])
}

model VendorTransaction {
  id              Int     @id @default(autoincrement())
  organizationId  Int     @default(1)
  vendorId        Int
  vendor          Vendors @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type            String
  amount          Float
  description     String
  reference       String?
  invoice         String?
  previousBalance Float
  newBalance      Float
  createdAt       DateTime @default(now())

  @@index([vendorId])
  @@index([createdAt])
  @@index([organizationId])
}

model vendorservice {
  id             Int    @id @default(autoincrement())
  organizationId Int    @default(1)
  vendor         String
  service        String

  @@unique([organizationId, vendor, service])
  @@index([organizationId])
}

/// Accounts module: Payments
enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  ADJUSTMENT
  EQUITY
}

enum PartyType {
  US
  CUSTOMER
  VENDOR
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
}

model Payment {
  id              Int             @id @default(autoincrement())
  organizationId  Int             @default(1)
  transactionType TransactionType
  category        String
  date            DateTime
  amount          Float
  fromPartyType   PartyType
  fromCustomerId  Int?
  fromCustomer    String
  toPartyType     PartyType
  toVendorId      Int?
  toVendor        String
  mode            PaymentMode?
  reference       String?
  invoice         String?
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
}

model Invoice {
  id              Int       @id @default(autoincrement())
  organizationId  Int       @default(1)
  invoiceNumber   String    @unique
  invoiceDate     DateTime
  receiptNumber   String?
  trackingNumber  String?
  destination     String
  dayWeek         String?
  weight          Float
  profile         String
  fscCharges      Float     @default(0)
  discount        Float     @default(0)
  lineItems       Json
  customerId      Int?
  customer        Customers? @relation(fields: [customerId], references: [id])
  vendorId        Int?
  vendor          Vendors?   @relation(fields: [vendorId], references: [id])
  shipmentId      Int?
  shipment        Shipment?  @relation(fields: [shipmentId], references: [id])
  disclaimer      String?
  status          String    @default("Unpaid")
  totalAmount     Float
  currency        String    @default("USD")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  debitNotes      DebitNote[]
  creditNotes     CreditNote[]

  @@index([organizationId])
}

model DebitNote {
  id              Int      @id @default(autoincrement())
  debitNoteNumber String   @unique
  billId          Int?
  bill            Invoice? @relation(fields: [billId], references: [id])
  vendorId        Int?
  vendor          Vendors? @relation(fields: [vendorId], references: [id])
  amount          Float
  date            DateTime
  description     String?
  currency        String   @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CreditNote {
  id               Int       @id @default(autoincrement())
  creditNoteNumber String    @unique
  invoiceId        Int?
  invoice          Invoice?  @relation(fields: [invoiceId], references: [id])
  customerId       Int
  customer         Customers @relation(fields: [customerId], references: [id])
  amount           Float
  date             DateTime
  description      String?
  currency         String    @default("USD")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ChartOfAccount {
  id             Int                @id @default(autoincrement())
  organizationId Int                @default(1)
  code           String
  accountName    String
  category       String
  type           String
  debitRule      String
  creditRule     String
  description    String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  journalLines   JournalEntryLine[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model JournalEntry {
  id             Int                @id @default(autoincrement())
  organizationId Int                @default(1)
  entryNumber    String
  date           DateTime
  description    String
  reference      String?
  totalDebit     Float
  totalCredit    Float
  isPosted       Boolean            @default(false)
  postedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  lines          JournalEntryLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId])
}

model JournalEntryLine {
  id             Int            @id @default(autoincrement())
  journalEntryId Int
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      Int
  account        ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  debitAmount    Float          @default(0)
  creditAmount   Float          @default(0)
  description    String?
  reference      String?
  createdAt      DateTime       @default(now())
}

model FixedCharge {
  id             Int      @id @default(autoincrement())
  organizationId Int      @default(1)
  weight         Float
  fixedCharge    Float
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

model AppSetting {
  key   String @id
  value String
}

model PaymentProof {
  id             Int          @id @default(autoincrement())
  organizationId Int
  planId         Int
  amount         Float
  method         String       // BANK_TRANSFER | EASYPAISA | JAZZCASH | CASH
  referenceId    String       // Transaction/Reference ID
  receiptUrl     String?      // Screenshot/Receipt upload URL
  status         String       @default("pending") // pending | approved | rejected
  notes          String?      // Optional admin notes
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([organizationId])
}
