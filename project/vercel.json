{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-inactive-customers",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 0 * * *"
    }
  ]
}
